<h1><%= @place["name"] %></h1>

<p>
  <a href="/places">Back to All Places</a>
</p>

<h2>Entries</h2>

<% @entries.each do |entry| %>
  <h3><%= entry["title"] %></h3>
  <p><%= entry["posted_on"] %></p>
  <p><%= entry["description"] %></p>
<% end %>

<p>
  <a href="/entries/new?place_id=<%= @place["id"] %>">New Post</a>
</p>
